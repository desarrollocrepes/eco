# Copiar este archivo como .env.local y completar los valores

# URL Base (Se detecta automáticamente en Vercel)
VITE_BASE_URL=http://localhost:5174

# Stripe (Opcional - si agregas pagos después)
VITE_STRIPE_PUBLIC_KEY=pk_test_XXXXXXXXXX

# SendGrid (Opcional - si agregas emails después)
VITE_SENDGRID_API_KEY=SG.XXXXXXXXXX

# Google Analytics (Opcional)
VITE_GA_ID=G-XXXXXXXXXX

# Auth0 (Opcional - si agregas autenticación después)
VITE_AUTH0_DOMAIN=tu-dominio.auth0.com
VITE_AUTH0_CLIENT_ID=XXXXXXXXXX
